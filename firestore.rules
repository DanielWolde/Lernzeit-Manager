rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function isOwnerExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    // goals
    match /goals/{docId} {
      allow create: if isOwner();
      allow read, update, delete: if isOwnerExisting();
    }

    // learningSessions
    match /learningSessions/{docId} {
      allow create: if isOwner();
      allow read, update, delete: if isOwnerExisting();
    }

    // monthlyPlans
    match /monthlyPlans/{docId} {
      allow create: if isOwner();
      allow read, update, delete: if isOwnerExisting();
    }
  }
}

flowchart TD
    A(["Nutzer öffnet App"])

    A --> B{"Eingeloggt?"}
    B -->|"Nein"| C["LoginPage\nEmail + Passwort"]
    C -->|"signIn()"| FB_AUTH["Firebase Auth"]
    FB_AUTH -->|"User-Objekt"| D

    B -->|"Ja"| D["Home laden"]
    D --> E["Firestore\nZiele · Sessions · Pläne\nparallel laden"]

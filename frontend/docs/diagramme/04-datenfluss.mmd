    FS2 --> F

    F --> J(["Monatsplan speichern"])
    J --> FS3["Firestore\nsaveMonthlyPlan()"]
    FS3 --> F

    style FB_AUTH fill:#fef9c3,stroke:#ca8a04
    style LS fill:#f3e8ff,stroke:#9333ea
    style FS1 fill:#dbeafe,stroke:#3b82f6
    style FS2 fill:#dbeafe,stroke:#3b82f6
    style FS3 fill:#dbeafe,stroke:#3b82f6
    style F fill:#dcfce7,stroke:#16a34a

    F --> G(["Nutzer startet Timer"])
    G --> LS["localStorage\nStartzeit speichern"]
    LS --> H(["Nutzer stoppt Timer"])
    H --> FS1["Firestore\nsaveSession()"]
    FS1 --> F

    F --> I(["Neues Ziel anlegen"])
